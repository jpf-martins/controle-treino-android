<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_background"
    android:padding="24dp">

    <TextView
        android:id="@+id/txtTituloUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Perfil do Usuário"
        android:textColor="@color/app_text_primary"
        android:textSize="26sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtNomeUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/app_accent"
        android:hint="Nome"
        android:inputType="textCapWords"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_secondary" />

    <EditText
        android:id="@+id/edtPesoUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/app_accent"
        android:hint="Peso"
        android:inputType="numberDecimal"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_secondary" />

    <EditText
        android:id="@+id/edtAlturaUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/app_accent"
        android:hint="Altura"
        android:inputType="numberDecimal"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_secondary" />

    <EditText
        android:id="@+id/edtMetaUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/app_accent"
        android:hint="Meta"
        android:inputType="textCapWords"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_secondary" />

    <Button
        android:id="@+id/btnSalvarUsuario"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/app_accent"
        android:text="Salvar usuário"
        android:textAllCaps="false"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/listaUsuarios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_weight="1"
        android:divider="@color/app_divider"
        android:dividerHeight="1dp" />

</LinearLayout>