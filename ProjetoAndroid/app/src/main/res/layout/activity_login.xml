<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_app_gradient"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/txtTituloLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Controle de Treino"
        android:textColor="@color/app_text_primary"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtSubtituloLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Entre para acompanhar seus treinos"
        android:textColor="@color/app_text_secondary"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/edtEmailLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/app_accent"
        android:hint="E-mail"
        android:inputType="textEmailAddress"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_secondary" />

    <EditText
        android:id="@+id/edtSenhaLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/app_accent"
        android:hint="Senha"
        android:inputType="textPassword"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_secondary" />

    <Button
        android:id="@+id/btnEntrar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/app_accent"
        android:text="Entrar"
        android:textAllCaps="false"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnIrCadastro"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/app_card"
        android:text="Criar conta"
        android:textAllCaps="false"
        android:textColor="@color/app_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>